<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ControlInventarioMovil.Views.EmployeesPage"
             Shell.NavBarIsVisible="False"
             Title="Gestión de Personal"
             BackgroundColor="{AppThemeBinding Light=#F4F6F7, Dark=#1C262E}">

    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="15,20,15,10" BackgroundColor="{AppThemeBinding Light=#1B4F5F, Dark=#161F27}">
            <ImageButton Grid.Column="0" Source="arrow_back.png" WidthRequest="28" HeightRequest="28" BackgroundColor="Transparent" Padding="0" Clicked="OnVolverClicked"/>
            <Label Grid.Column="1" Text="PANEL DE COLABORADORES" TextColor="White" FontAttributes="Bold" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" CharacterSpacing="0.5"/>
            <BoxView Grid.Column="2" WidthRequest="30" BackgroundColor="Transparent"/>
        </Grid>

        <Grid Grid.Row="1" Padding="15" RowDefinitions="Auto, *">

            <Border Grid.Row="0" StrokeShape="RoundRectangle 8" Stroke="{AppThemeBinding Light=#CDD5DB, Dark=#2E3842}" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#232B35}" Padding="12,0" HeightRequest="45" Margin="0,5,0,15">
                <Grid ColumnDefinitions="Auto, *">
                    <Image Grid.Column="0" Source="search_icon.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center" Margin="4,0,8,0"/>
                    <Entry Grid.Column="1" x:Name="txtSearchEmployee" Placeholder="Buscar por nombre o DNI..." TextColor="{AppThemeBinding Light=#1C262E, Dark=White}" PlaceholderColor="{AppThemeBinding Light=#8895A5, Dark=#606A72}" VerticalOptions="Center" TextChanged="OnSearchTextChanged"/>
                </Grid>
            </Border>

            <RefreshView Grid.Row="1" x:Name="refreshEmployees" Refreshing="OnRefreshRequested">
                <CollectionView x:Name="listEmployees" SelectionMode="None">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light=#CDD5DB, Dark=#2E3842}" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#232B35}" Padding="15">
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">

                                    <Border Grid.Column="0" WidthRequest="44" HeightRequest="44" StrokeShape="RoundRectangle 22" Stroke="Transparent" BackgroundColor="#0000FF" VerticalOptions="Center">
                                        <Grid>
                                            <Label Text="{Binding FirstName[0]}" TextColor="White" FontAttributes="Bold" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>

                                            <Image Source="{Binding PictureUrl}" Aspect="AspectFill" />
                                        </Grid>
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="{Binding FirstName}" TextColor="{AppThemeBinding Light=#1C262E, Dark=White}" FontAttributes="Bold" FontSize="14"/>
                                            <Label Text="{Binding LastName}" TextColor="{AppThemeBinding Light=#1C262E, Dark=White}" FontAttributes="Bold" FontSize="14"/>
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding DNI, StringFormat='DNI: {0}'}" TextColor="{AppThemeBinding Light=#54606C, Dark=#606A72}" FontSize="11"/>
                                    </VerticalStackLayout>

                                    <ImageButton Grid.Column="2" Source="edit_icon.png" WidthRequest="24" HeightRequest="24" BackgroundColor="Transparent" VerticalOptions="Center" Clicked="OnEditEmployeeClicked" CommandParameter="{Binding .}"/>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

            <Button Grid.Row="1" Text="+" BackgroundColor="#0000FF" TextColor="White" FontSize="26" FontAttributes="Bold" WidthRequest="56" HeightRequest="56" CornerRadius="28" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,10,10" Clicked="OnAddEmployeeClicked"/>

        </Grid>
    </Grid>
</ContentPage>