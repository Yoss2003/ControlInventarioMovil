<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ControlInventarioMovil.Views.InventoryPage"
             Title="Inventario Real"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1C262E">
    <Grid RowDefinitions="Auto, *, Auto">

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="20,20,15,15" BackgroundColor="#161F27">
            <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                <Label x:Name="LblNombreAlmacen" Text="ALMACÉN ACTIVO" TextColor="#A2D149" FontAttributes="Bold" FontSize="15" CharacterSpacing="0.5"/>
                <Label Text="Listado oficial de existencias en tiempo real" TextColor="#606A72" FontSize="11"/>
            </VerticalStackLayout>
            <ImageButton Grid.Column="1" Source="config_icon.png" WidthRequest="22" HeightRequest="22" BackgroundColor="Transparent" VerticalOptions="Center" Margin="0,0,10,0" Opacity="0.8" Clicked="OnConfigCategoriesClicked"/>
        </Grid>

        <Grid Grid.Row="1" Padding="15,12">
            <ActivityIndicator x:Name="ActCargando" IsRunning="False" IsVisible="False" Color="#A2D149" HorizontalOptions="Center" VerticalOptions="Center" HeightRequest="40" WidthRequest="40"/>

            <VerticalStackLayout x:Name="SecEstadoVacio" IsVisible="False" VerticalOptions="Center" Spacing="10">
                <Image Source="reportes.png" HeightRequest="50" WidthRequest="50" Opacity="0.3" HorizontalOptions="Center"/>
                <Label Text="Almacén sin existencias" TextColor="#939CA5" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                <Label Text="Presiona el botón inferior para registrar el primer artículo en este ambiente." TextColor="#606A72" FontSize="12" HorizontalTextAlignment="Center" Padding="30,0"/>
            </VerticalStackLayout>

            <CollectionView x:Name="CvwArticulos" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,0,0,10">
                            <Border StrokeShape="RoundRectangle 8" Stroke="#26313C" BackgroundColor="#222B34" Padding="15,14">
                                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto" RowSpacing="0">

                                    <Label Grid.Row="0" Grid.Column="0" Text="{Binding Name}" TextColor="White" FontAttributes="Bold" FontSize="14" LineBreakMode="TailTruncation" VerticalOptions="Center"/>

                                    <HorizontalStackLayout Grid.Row="0" Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center" Spacing="4">
                                        <Label Text="{Binding AcquisitionCurrency}" TextColor="#EFA72F" FontAttributes="Bold" FontSize="12" VerticalOptions="Center"/>
                                        <Label Text="{Binding SalePrice, StringFormat='S/. {0:F2}'}" TextColor="#A2D149">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding SalePrice}" Value="{x:Null}">
                                                    <Setter Property="IsVisible" Value="False"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="8" Margin="0,6,0,0">
                                        <Border BackgroundColor="#161F27" StrokeShape="RoundRectangle 4" Padding="6,2" StrokeThickness="0">
                                            <Label Text="{Binding Code}" TextColor="#A2D149" FontSize="10" FontAttributes="Bold"/>
                                        </Border>
                                        <Label Text="{Binding MeasurementUnit}" TextColor="#788591" FontSize="11" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>

                                    <Label Grid.Row="1" Grid.Column="1" Text="P. Venta" TextColor="#54606C" FontSize="9" HorizontalOptions="End" Margin="0,2,0,0"/>

                                    <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*, Auto" Margin="0,15,0,0">
                                        <HorizontalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                                            <Label Text="Existencia en Almacén:" TextColor="#939CA5" FontSize="12" VerticalOptions="Center"/>
                                            <Label Text="{Binding Stock, StringFormat='{0:0.##}'}" TextColor="#A2D149" FontAttributes="Bold" FontSize="15" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <ImageButton Grid.Column="1" 
                                                     Source="edit_icon.png" 
                                                     WidthRequest="22" 
                                                     HeightRequest="22" 
                                                     BackgroundColor="Transparent" 
                                                     VerticalOptions="Center" 
                                                     HorizontalOptions="End"
                                                     Padding="0"
                                                     Opacity="0.8"
                                                     CommandParameter="{Binding .}"
                                                     Clicked="OnEditarArticuloClicked"/>
                                    </Grid>

                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="12" Padding="15,12,15,15" BackgroundColor="#161F27">
            <Button Grid.Column="0" Text="PANEL PRINCIPAL" BackgroundColor="#2E3842" TextColor="#939CA5" FontAttributes="Bold" CornerRadius="6" HeightRequest="42" FontSize="12" Clicked="OnVolverClicked"/>
            <Button Grid.Column="1" Text="+ NUEVO ARTÍCULO" BackgroundColor="#A2D149" TextColor="#1C262E" FontAttributes="Bold" CornerRadius="6" HeightRequest="42" FontSize="12" Clicked="OnAgregarArticuloClicked"/>
        </Grid>

    </Grid>
</ContentPage>