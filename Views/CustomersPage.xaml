<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ControlInventarioMovil.Views.CustomersPage"
             Shell.NavBarIsVisible="False"
             Title="Mis Caseritos" BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#0F151A}">
    
    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Margin="16,12" Padding="12,2" StrokeThickness="1" Stroke="#20808080" BackgroundColor="{AppThemeBinding Light=White, Dark=#171F24}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto, *">
                <Image Source="search_icon.svg" WidthRequest="20" HeightRequest="20" VerticalOptions="Center" Margin="4,0,8,0"/>
                <Entry Grid.Column="1" x:Name="txtSearchCustomer" Placeholder="Buscar..." TextColor="{AppThemeBinding Light=Black, Dark=White}" TextChanged="OnSearchTextChanged"/>
            </Grid>
        </Border>

        <RefreshView Grid.Row="1" x:Name="refreshCustomers" Refreshing="OnRefreshRequested">
            <CollectionView x:Name="listCustomers" SelectionMode="None" Margin="16,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,0,0,12">
                            <Border Padding="16" BackgroundColor="{AppThemeBinding Light=White, Dark=#171F24}" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                                    <Border Grid.Column="0" WidthRequest="44" HeightRequest="44" BackgroundColor="#8A2BE2" StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="22" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Name[0]}" TextColor="White" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16"/>
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{Binding DocumentNumber}" TextColor="Gray" FontSize="13"/>
                                            <Label Text="•" TextColor="Gray" FontSize="13"/>
                                            <Label Text="{Binding Phone}" TextColor="Gray" FontSize="13"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                    <ImageButton Grid.Column="2" Source="edit_icon.svg" WidthRequest="22" HeightRequest="22" CommandParameter="{Binding .}" Clicked="OnEditCustomerClicked"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
        <Button Grid.Row="1" Text="+" TextColor="White" FontSize="28" BackgroundColor="#8A2BE2" WidthRequest="56" HeightRequest="56" CornerRadius="28" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,24,24" Clicked="OnAddCustomerClicked"/>
    </Grid>
</ContentPage>