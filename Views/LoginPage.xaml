<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ControlInventarioMovil.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             Title="LoginPage">

    <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

        <Image Source="dotnet_bot.png" HeightRequest="100" HorizontalOptions="Center" />

        <Label Text="Bienvenido" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" />
        <Label Text="Inicia sesión para continuar" TextColor="Gray" HorizontalOptions="Center" />

        <Entry x:Name="txtUser" Placeholder="Usuario" />
        <Entry x:Name="txtPass" Placeholder="Contraseña" IsPassword="True" />

        <Button Text="ENTRAR" 
                Clicked="OnLoginClicked"
                BackgroundColor="#512BD4" 
                TextColor="White" 
                HeightRequest="50"
                CornerRadius="25" />

        <ActivityIndicator x:Name="loading" IsRunning="False" Color="#512BD4" />
    </VerticalStackLayout>
</ContentPage>