<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"             
             xmlns:models="clr-namespace:ControlInventario.Shared.Models;assembly=ControlInventario.Shared"             
             x:Class="ControlInventarioMovil.Views.EditProfilePage"
             BackgroundColor="#F9F9F9"
             Shell.NavBarIsVisible="False"
             x:DataType="models:User">

    <Grid>

        <Grid RowDefinitions="Auto, *">
            <Grid Grid.Row="0" BackgroundColor="#1B4F5F" Padding="15,20" ColumnDefinitions="Auto, *">
                <Image Source="arrow_back.png" HeightRequest="25" WidthRequest="25" Grid.Column="0" VerticalOptions="Center">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCancelClicked"/>
                    </Image.GestureRecognizers>
                </Image>
                <Label Text="Editar Perfil" TextColor="White" FontSize="20" FontAttributes="Bold" 
                       VerticalOptions="Center" HorizontalOptions="Center" Grid.Column="1" Margin="0,0,25,0"/>
            </Grid>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="15,20,15,30" Spacing="15">

                    <VerticalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,0,0,5">
                        <Border HeightRequest="110" WidthRequest="110" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="55"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="5" Opacity="0.2"/>
                            </Border.Shadow>
                            <Image x:Name="imgProfilePreview" Source="user_outline.png" Aspect="AspectFill" HeightRequest="110" WidthRequest="110"/>
                        </Border>
                        <Label Text="Cambiar Foto" TextColor="#1B4F5F" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,5,0,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChangePhotoTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>

                    <Border BackgroundColor="White" StrokeThickness="0" Padding="15">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1"/>
                        </Border.Shadow>

                        <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, *" RowSpacing="15" ColumnSpacing="15">

                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="5">
                                <Label Text="Nombres *" FontAttributes="Bold" TextColor="Black" FontSize="12"/>
                                <Entry x:Name="txtFirstName" Text="{Binding FirstName}" TextColor="Black" BackgroundColor="#F5F5F5" FontSize="14" MaxLength="50" TextChanged="OnNameFieldsChanged"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="5">
                                <Label Text="Apellidos *" FontAttributes="Bold" TextColor="Black" FontSize="12"/>
                                <Entry x:Name="txtLastName" Text="{Binding LastName}" TextColor="Black" BackgroundColor="#F5F5F5" FontSize="14" MaxLength="50" TextChanged="OnNameFieldsChanged"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="5">
                                <Label Text="Usuario (Auto)" FontAttributes="Bold" TextColor="Black" FontSize="12"/>
                                <Entry x:Name="txtUsername" Text="{Binding Username}" TextColor="Black" BackgroundColor="#E0E0E0" FontSize="14" IsReadOnly="True"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="5">
                                <Label Text="Teléfono" FontAttributes="Bold" TextColor="Black" FontSize="12"/>
                                <Entry x:Name="txtPhoneNumber" Text="{Binding PhoneNumber}" Keyboard="Telephone" TextColor="Black" BackgroundColor="#F5F5F5" FontSize="14"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="5">
                                <Label Text="Correo Electrónico *" FontAttributes="Bold" TextColor="Black" FontSize="12"/>
                                <Entry x:Name="txtEmail" Text="{Binding Email}" Keyboard="Email" TextColor="Black" BackgroundColor="#F5F5F5" FontSize="14"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <Border BackgroundColor="White" StrokeThickness="0" Padding="15">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1"/>
                        </Border.Shadow>

                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="15" VerticalOptions="Center">
                            <VerticalStackLayout Grid.Column="0" Spacing="5" VerticalOptions="Center">
                                <Label Text="Nueva Contraseña (Opcional)" FontAttributes="Bold" TextColor="Black" FontSize="12"/>
                                <Entry x:Name="txtPassword" IsPassword="True" Placeholder="Dejar en blanco para no cambiar" TextColor="Black" BackgroundColor="#F5F5F5" FontSize="13"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="Estado (Activo)" FontAttributes="Bold" TextColor="Black" FontSize="12" HorizontalTextAlignment="Center"/>
                                <Switch x:Name="swIsActive" IsToggled="{Binding IsActive}" OnColor="#1B4F5F" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <Border BackgroundColor="White" StrokeThickness="0" Padding="15">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.1"/>
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="15">

                            <VerticalStackLayout Spacing="5">
                                <Label Text="Rol del Sistema *" FontAttributes="Bold" TextColor="Black" FontSize="12"/>
                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                                    <Picker x:Name="pckRole" Grid.Column="0" Title="Seleccione un Rol" ItemDisplayBinding="{Binding Name}" x:DataType="{x:Null}" TextColor="Black" TitleColor="Gray" BackgroundColor="#F5F5F5"/>
                                    <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                        <Button Text="+" WidthRequest="36" HeightRequest="36" Padding="0" CornerRadius="18" BackgroundColor="#1B4F5F" TextColor="White" FontAttributes="Bold" FontSize="20" Clicked="OnAddRoleClicked"/>
                                        <Button Text="✏️" WidthRequest="36" HeightRequest="36" Padding="0" CornerRadius="18" BackgroundColor="#E67E22" TextColor="White" FontSize="14" Clicked="OnEditRoleClicked"/>
                                    </HorizontalStackLayout>
                                </Grid>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="Área de Trabajo *" FontAttributes="Bold" TextColor="Black" FontSize="12"/>
                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                                    <Picker x:Name="pckArea" Grid.Column="0" Title="Seleccione el Área" ItemDisplayBinding="{Binding Name}" x:DataType="{x:Null}" TextColor="Black" TitleColor="Gray" BackgroundColor="#F5F5F5"/>
                                    <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                        <Button Text="+" WidthRequest="36" HeightRequest="36" Padding="0" CornerRadius="18" BackgroundColor="#1B4F5F" TextColor="White" FontAttributes="Bold" FontSize="20" Clicked="OnAddAreaClicked"/>
                                        <Button Text="✏️" WidthRequest="36" HeightRequest="36" Padding="0" CornerRadius="18" BackgroundColor="#E67E22" TextColor="White" FontSize="14" Clicked="OnEditAreaClicked"/>
                                    </HorizontalStackLayout>
                                </Grid>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="Puesto de Trabajo *" FontAttributes="Bold" TextColor="Black" FontSize="12"/>
                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                                    <Picker x:Name="pckPosition" Grid.Column="0" Title="Seleccione el Puesto" ItemDisplayBinding="{Binding Name}" x:DataType="{x:Null}" TextColor="Black" TitleColor="Gray" BackgroundColor="#F5F5F5"/>
                                    <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                        <Button Text="+" WidthRequest="36" HeightRequest="36" Padding="0" CornerRadius="18" BackgroundColor="#1B4F5F" TextColor="White" FontAttributes="Bold" FontSize="20" Clicked="OnAddPositionClicked"/>
                                        <Button Text="✏️" WidthRequest="36" HeightRequest="36" Padding="0" CornerRadius="18" BackgroundColor="#E67E22" TextColor="White" FontSize="14" Clicked="OnEditPositionClicked"/>
                                    </HorizontalStackLayout>
                                </Grid>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="Tipo de Contrato" FontAttributes="Bold" TextColor="Black" FontSize="12"/>
                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                                    <Picker x:Name="pckContractType" Grid.Column="0" Title="Seleccione el Contrato" ItemDisplayBinding="{Binding Name}" x:DataType="{x:Null}" TextColor="Black" TitleColor="Gray" BackgroundColor="#F5F5F5"/>
                                    <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                        <Button Text="+" WidthRequest="36" HeightRequest="36" Padding="0" CornerRadius="18" BackgroundColor="#1B4F5F" TextColor="White" FontAttributes="Bold" FontSize="20" Clicked="OnAddContractTypeClicked"/>
                                        <Button Text="✏️" WidthRequest="36" HeightRequest="36" Padding="0" CornerRadius="18" BackgroundColor="#E67E22" TextColor="White" FontSize="14" Clicked="OnEditContractTypeClicked"/>
                                    </HorizontalStackLayout>
                                </Grid>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                    <Button x:Name="btnSave" Text="Guardar Cambios" BackgroundColor="#1B4F5F" TextColor="White" 
                            FontAttributes="Bold" FontSize="16" CornerRadius="25" HeightRequest="50" Margin="0,10,0,10"
                            Clicked="OnSaveClicked"/>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>


        <Grid x:Name="PopupOverlay" BackgroundColor="#80000000" IsVisible="False" Padding="20">
            <Border BackgroundColor="White" VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="320" Padding="20" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.3"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="15">
                    <Label x:Name="lblPopupTitle" Text="Nuevo Registro" FontAttributes="Bold" FontSize="20" TextColor="#1B4F5F" HorizontalOptions="Center"/>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Nombre:" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
                        <Entry x:Name="txtPopupName" Placeholder="Escriba aquí..." TextColor="Black" BackgroundColor="#F5F5F5"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="layoutPopupDesc" Spacing="5">
                        <Label Text="Descripción (Opcional):" FontAttributes="Bold" FontSize="14" TextColor="Black"/>
                        <Entry x:Name="txtPopupDesc" Placeholder="Detalles..." TextColor="Black" BackgroundColor="#F5F5F5"/>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,15,0,0">
                        <Button Grid.Column="0" Text="Cancelar" BackgroundColor="#D3D3D3" TextColor="Black" FontAttributes="Bold" CornerRadius="8" Clicked="OnClosePopupClicked"/>
                        <Button Grid.Column="1" Text="Guardar" BackgroundColor="#1B4F5F" TextColor="White" FontAttributes="Bold" CornerRadius="8" Clicked="OnSavePopupClicked"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>