<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ControlInventarioMovil.Views.CustomerFormPage"
             Shell.NavBarIsVisible="False"
             x:Name="thisPage"
             BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#0F151A}">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16">

            <VerticalStackLayout Spacing="6">
                <Label Text="Documento de Identidad (DNI/RUC)" TextColor="Gray" FontSize="14" FontAttributes="Bold"/>
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                    <Border Padding="12,0" HeightRequest="45" StrokeThickness="1" Stroke="#20808080" BackgroundColor="{AppThemeBinding Light=White, Dark=#171F24}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Entry x:Name="txtDocumentNumber" Keyboard="Numeric" MaxLength="11" TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center"/>
                    </Border>
                    <Button Grid.Column="1" 
                            Text="🔍 Consultar" 
                            BackgroundColor="#00CED1" 
                            TextColor="White" 
                            FontAttributes="Bold"
                            HeightRequest="45" 
                            CornerRadius="8"
                            Clicked="OnConsultIdentityClicked"/>
                </Grid>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="Nombre / Razón Social *" TextColor="Gray" FontSize="14" FontAttributes="Bold"/>
                <Border Padding="12,0" HeightRequest="45" StrokeThickness="1" Stroke="#20808080" BackgroundColor="{AppThemeBinding Light=White, Dark=#171F24}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Entry x:Name="txtName" TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="Teléfono / Celular" TextColor="Gray" FontSize="14" FontAttributes="Bold"/>
                <Border Padding="12,0" HeightRequest="45" StrokeThickness="1" Stroke="#20808080" BackgroundColor="{AppThemeBinding Light=White, Dark=#171F24}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Entry x:Name="txtPhone" Keyboard="Telephone" TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="Correo Electrónico" TextColor="Gray" FontSize="14" FontAttributes="Bold"/>
                <Border Padding="12,0" HeightRequest="45" StrokeThickness="1" Stroke="#20808080" BackgroundColor="{AppThemeBinding Light=White, Dark=#171F24}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Entry x:Name="txtEmail" Keyboard="Email" TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center"/>
                </Border>
            </VerticalStackLayout>

            <Button Text="GUARDAR CASERITO" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    HeightRequest="48" 
                    CornerRadius="10" 
                    Margin="0,12,0,0"
                    Clicked="OnSaveClicked">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#8A2BE2" Offset="0.0" />
                        <GradientStop Color="#0000FF" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>