<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ControlInventarioMovil.Views.UserManagementPage"
             Title="Control de Personal">

    <Grid RowDefinitions="Auto, *" Padding="15" RowSpacing="15">
        <Button Text="+ REGISTRAR NUEVO MIEMBRO" Clicked="OnAddUserClicked" BackgroundColor="#2E7D32" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="46"/>

        <RefreshView Grid.Row="1" x:Name="RefreshUsers" Refreshing="OnRefreshing">
            <CollectionView x:Name="CvUsers">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeShape="RoundRectangle 10" Stroke="{AppThemeBinding Light=#CDD5DB, Dark=#2E3842}" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#161F27}" Margin="0,0,0,12" Padding="12,15">
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">

                                <Border Grid.Column="0" StrokeShape="RoundRectangle 20" WidthRequest="40" HeightRequest="40" StrokeThickness="0" VerticalOptions="Center">
                                    <Grid>
                                        <Border BackgroundColor="#2E7D32" StrokeShape="RoundRectangle 20">
                                            <Label Text="👤" TextColor="White" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                        <Image Source="{Binding ProfilePictureUrl}" Aspect="AspectFill" WidthRequest="40" HeightRequest="40">
                                            <Image.Triggers>
                                                <DataTrigger TargetType="Image" Binding="{Binding ProfilePictureUrl}" Value="{x:Null}">
                                                    <Setter Property="IsVisible" Value="False"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Image" Binding="{Binding ProfilePictureUrl}" Value="">
                                                    <Setter Property="IsVisible" Value="False"/>
                                                </DataTrigger>
                                            </Image.Triggers>
                                        </Image>
                                    </Grid>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding FirstName}" FontAttributes="Bold" FontSize="15" TextColor="{AppThemeBinding Light=#1C262E, Dark=White}"/>
                                    <Grid ColumnDefinitions="Auto, *">
                                        <Label Grid.Column="0" Text="ID: " FontSize="12" TextColor="#606A72" FontAttributes="Bold"/>
                                        <Label Grid.Column="1" Text="{Binding Username}" FontSize="12" TextColor="{AppThemeBinding Light=#54606C, Dark=#939CA5}"/>
                                    </Grid>
                                </VerticalStackLayout>

                                <HorizontalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="15">
                                    <Border StrokeShape="RoundRectangle 6" BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B301F}" Padding="8,4" VerticalOptions="Center" StrokeThickness="0">
                                        <Label Text="{Binding Role.Name}" FontSize="10" FontAttributes="Bold" TextColor="#A2D149"/>
                                    </Border>
                                    <ImageButton Source="edit_icon.png" Clicked="OnEditUserClicked" CommandParameter="{Binding .}" HeightRequest="26" WidthRequest="26" VerticalOptions="Center"/>
                                </HorizontalStackLayout>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>