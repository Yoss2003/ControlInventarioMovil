<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ControlInventarioMovil.Views.ArticleFormPage"
             Title="Detalle de Artículo"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1C262E">
    <Grid>
        <Grid RowDefinitions="Auto, *, 70">
            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="15,20,15,15" BackgroundColor="#1C262E">
                <ImageButton Grid.Column="0" Source="arrow_back.png" WidthRequest="28" HeightRequest="28" BackgroundColor="Transparent" Clicked="OnVolverClicked"/>
                <Label x:Name="LblTituloFormulario" Grid.Column="1" Text="INGRESO DE ARTÍCULO MULTIAMBIENTE" TextColor="White" FontAttributes="Bold" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center"/>
                <ImageButton Grid.Column="2" Source="config_icon.png" WidthRequest="30" HeightRequest="30" BackgroundColor="Transparent"/>
            </Grid>

            <ScrollView Grid.Row="1" Padding="15">
                <VerticalStackLayout Spacing="22">

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">

                        <Border Grid.Column="0" 
            WidthRequest="150" HeightRequest="150" 
            StrokeShape="RoundRectangle 12" Stroke="#2E3842" 
            BackgroundColor="#232B35" Padding="0" 
            HorizontalOptions="Center" >
                            <Grid>
                                <Image x:Name="ImgArticuloPreview" 
                   Aspect="AspectFill" 
                   HorizontalOptions="Fill" VerticalOptions="Fill" 
                   IsVisible="False">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnVerFotoPrincipalClicked"/>
                                    </Image.GestureRecognizers>
                                </Image>

                                <VerticalStackLayout x:Name="PlaceholderArticulo" 
                                 VerticalOptions="Center" HorizontalOptions="Center" 
                                 Spacing="8">
                                    <VerticalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTomarFotoPrincipalClicked"/>
                                    </VerticalStackLayout.GestureRecognizers>
                                    <Image Source="config_icon.png" HeightRequest="32" WidthRequest="32" HorizontalOptions="Center"/>
                                    <Label Text="Foto del Artículo" TextColor="#606A72" FontSize="11" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>

                                <ImageButton x:Name="BtnBorrarFotoPrincipal"
                         Source="delete_icon.png" 
                         WidthRequest="26" HeightRequest="26"
                         HorizontalOptions="End" VerticalOptions="Start"
                         Margin="8" IsVisible="False"
                         Clicked="OnBorrarFotoPrincipalClicked"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" 
            WidthRequest="150" HeightRequest="150" 
            StrokeShape="RoundRectangle 12" Stroke="#2E3842" 
            BackgroundColor="#232B35" Padding="0" 
            HorizontalOptions="Center" >
                            <Grid>
                                <Image x:Name="ImgVoucherPreview" 
                   Aspect="AspectFill" 
                   HorizontalOptions="Fill" VerticalOptions="Fill" 
                   IsVisible="False">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnVerFotoVoucherClicked"/>
                                    </Image.GestureRecognizers>
                                </Image>

                                <VerticalStackLayout x:Name="PlaceholderVoucher" 
                                 VerticalOptions="Center" HorizontalOptions="Center" 
                                 Spacing="8">
                                    <VerticalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTomarFotoComprobanteClicked"/>
                                    </VerticalStackLayout.GestureRecognizers>
                                    <Image Source="reportes.png" HeightRequest="32" WidthRequest="32" HorizontalOptions="Center"/>
                                    <Label Text="Foto Comprobante (Opc)" TextColor="#606A72" FontSize="11" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>

                                <ImageButton x:Name="BtnBorrarFotoVoucher"
                         Source="delete_icon.png" 
                         WidthRequest="26" HeightRequest="26"
                         HorizontalOptions="End" VerticalOptions="Start"
                         Margin="8" IsVisible="False"
                         Clicked="OnBorrarFotoVoucherClicked"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="CLASIFICACIÓN CORPORATIVA" TextColor="#A2D149" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Categoría *" TextColor="#939CA5" FontSize="12"/>
                            <Border StrokeShape="RoundRectangle 8" Stroke="#A2D149" BackgroundColor="#232B35" Padding="10,0">
                                <Grid>
                                    <Picker x:Name="PkrCategory" TextColor="White" BackgroundColor="Transparent" HeightRequest="40" SelectedIndexChanged="OnCategoryChanged"/>
                                    <Label x:Name="LblPlaceholderCategory" Text="Seleccione una categoría..." TextColor="#606A72" VerticalOptions="Center" InputTransparent="True"/>
                                </Grid>
                            </Border>
                            <Label x:Name="LblTrackingInfo" Text="Modo de Rastreo: Pendiente..." TextColor="#EFA72F" FontSize="11" FontAttributes="Bold" Margin="5,0,0,0"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="DATOS TÉCNICOS DEL PRODUCTO" TextColor="#A2D149" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>

                        <VerticalStackLayout x:Name="SecBarcode" Spacing="5" IsVisible="False">
                            <Label Text="Código de Barras EAN/UPC (Obligatorio en Caja) *" TextColor="#939CA5" FontSize="12"/>
                            <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                <Entry x:Name="TxtBarcode" TextColor="White" Placeholder="Escanee o digite el código de fábrica" PlaceholderColor="#606A72" HeightRequest="40"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="SecSku" Spacing="5">
                            <Label Text="Código SKU / Interno *" TextColor="#939CA5" FontSize="12"/>
                            <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                <Entry x:Name="TxtSku" TextColor="White" Placeholder="Ingrese SKU" PlaceholderColor="#606A72" HeightRequest="40" TextChanged="OnAutoNameTriggerChanged"/>
                            </Border>
                        </VerticalStackLayout>

                        <Grid x:Name="SecModelSerie" ColumnDefinitions="*, *" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Modelo" TextColor="#939CA5" FontSize="12"/>
                                <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                    <Entry x:Name="TxtModel" TextColor="White" Placeholder="Ej. L14 Gen 3" PlaceholderColor="#606A72" HeightRequest="40" TextChanged="OnAutoNameTriggerChanged"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Número de Serie" TextColor="#939CA5" FontSize="12"/>
                                <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                    <Entry x:Name="TxtSerialNumber" TextColor="White" Placeholder="S/N de fábrica" PlaceholderColor="#606A72" HeightRequest="40" TextChanged="OnAutoNameTriggerChanged"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout x:Name="ContenedorNombre" Spacing="5" IsVisible="False">
                            <Label Text="Nombre del Artículo *" TextColor="#939CA5" FontSize="12"/>
                            <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                <Entry x:Name="TxtName" TextColor="White" Placeholder="Nombre descriptivo" PlaceholderColor="#606A72" HeightRequest="40"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Marca *" TextColor="#939CA5" FontSize="12"/>
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                    <Grid>
                                        <Picker x:Name="PkrBrand" TextColor="White" BackgroundColor="Transparent" HeightRequest="40" SelectedIndexChanged="OnAutoNameTriggerChanged"/>
                                        <Label x:Name="LblPlaceholderBrand" Text="Seleccione una marca..." TextColor="#606A72" VerticalOptions="Center" InputTransparent="True"/>
                                    </Grid>
                                </Border>
                                <Button Grid.Column="1" Text="+" BackgroundColor="#2E3842" TextColor="#A2D149" FontAttributes="Bold" WidthRequest="45" HeightRequest="40" Clicked="OnAdministrarMarcasClicked"/>
                            </Grid>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Proveedor Asociado" TextColor="#939CA5" FontSize="12"/>
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0" HeightRequest="45" VerticalOptions="Center">
                                    <Picker x:Name="PkrSupplier" TextColor="White" BackgroundColor="Transparent" VerticalOptions="Center" SelectedIndexChanged="OnPickerIndexChanged"/>
                                </Border>
                                <Button Grid.Column="1" Text="+" BackgroundColor="#2E3842" TextColor="#A2D149" FontAttributes="Bold" FontSize="16" WidthRequest="45" HeightRequest="45" VerticalOptions="Center" Clicked="OnAdministrarProveedoresClicked"/>
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="INFORMACIÓN FINANCIERA DE TRANSACCIÓN" TextColor="#A2D149" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Costo Adquisición" TextColor="#939CA5" FontSize="12"/>
                                <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                    <Entry x:Name="TxtAcquisitionPrice" 
                       TextColor="White" 
                       Placeholder="0.00" 
                       Keyboard="Numeric" 
                       HeightRequest="40"
                       TextChanged="OnAcquisitionPriceChanged"/>
                                </Border>

                                <Label x:Name="LblConversionEquivalente" 
                   TextColor="#A2D149" 
                   FontSize="11" 
                   FontAttributes="Bold" 
                   Margin="5,2,0,0" 
                   IsVisible="False"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Precio Venta Estimado" TextColor="#939CA5" FontSize="12"/>
                                <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                    <Entry x:Name="TxtSalePrice" TextColor="White" Placeholder="0.00" Keyboard="Numeric" HeightRequest="40"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Moneda Adquisición" TextColor="#939CA5" FontSize="12"/>
                                <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                    <Picker x:Name="PkrCurrency" 
                        TextColor="White" 
                        BackgroundColor="Transparent" 
                        HeightRequest="40" 
                        SelectedIndexChanged="OnMonedaChanged"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Fecha Adquisición" TextColor="#939CA5" FontSize="12"/>
                                <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                    <DatePicker x:Name="DtpAcquisitionDate" TextColor="White" BackgroundColor="Transparent" HeightRequest="40"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="LOGÍSTICA, ALMACENAMIENTO Y STOCK" TextColor="#A2D149" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Unidad de Medida *" TextColor="#939CA5" FontSize="12"/>
                                <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                    <Grid>
                                        <Picker x:Name="PkrMeasurement" TextColor="White" BackgroundColor="Transparent" HeightRequest="40" SelectedIndexChanged="OnPickerIndexChanged"/>
                                        <Label x:Name="LblPlaceholderMeasurement" Text="Seleccione unidad..." TextColor="#606A72" VerticalOptions="Center" InputTransparent="True"/>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Stock Inicial *" TextColor="#939CA5" FontSize="12"/>
                                <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                    <Entry x:Name="TxtStock" TextColor="White" Placeholder="0" HeightRequest="40" Keyboard="Numeric"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Estado *" TextColor="#939CA5" FontSize="12"/>
                                <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                    <Picker x:Name="PkrStatusParam" TextColor="White" BackgroundColor="Transparent" HeightRequest="40" SelectedIndexChanged="OnPickerIndexChanged"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Ubicación / Almacén *" TextColor="#939CA5" FontSize="12"/>
                                <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                    <Picker x:Name="PkrLocationParam" TextColor="White" BackgroundColor="Transparent" HeightRequest="40" SelectedIndexChanged="OnPickerIndexChanged"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Condición Física *" TextColor="#939CA5" FontSize="12"/>
                            <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                <Picker x:Name="PkrConditionParam" TextColor="White" BackgroundColor="Transparent" HeightRequest="40" SelectedIndexChanged="OnPickerIndexChanged"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Observaciones Generales (Visible / Opcional)" TextColor="#939CA5" FontSize="12"/>
                            <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,5">
                                <Editor x:Name="TxtObservation" TextColor="White" Placeholder="Detalles sobre el estado del empaque, lote, etc..." HeightRequest="60"/>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="BloqueSerializadoCondicional" IsVisible="False" Spacing="15">
                        <Label Text="CONTROLES CORPORATIVOS DE ACTIVO FIJO" TextColor="#EFA72F" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Meses de Vida Útil *" TextColor="#939CA5" FontSize="12"/>
                                <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                    <Entry x:Name="TxtUsefulLife" TextColor="White" Placeholder="Ej. 48" Keyboard="Numeric" HeightRequest="40"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Vencimiento Garantía *" TextColor="#939CA5" FontSize="12"/>
                                <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                    <DatePicker x:Name="DtpWarranty" TextColor="White" BackgroundColor="Transparent" HeightRequest="40"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Especificaciones del Sistema" TextColor="#939CA5" FontSize="12"/>
                            <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,5">
                                <Editor x:Name="TxtCharacteristics" TextColor="White" Placeholder="RAM, Procesador, etc..." HeightRequest="65"/>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>

            <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="12" Padding="15,10,15,15" BackgroundColor="#161F27">
                <Button Grid.Column="0" Text="CANCELAR" BackgroundColor="#2E3842" TextColor="#939CA5" FontAttributes="Bold" CornerRadius="8" Clicked="OnCancelarClicked"/>
                <Button x:Name="BtnGuardar" Grid.Column="1" Text="GUARDAR INGRESO" BackgroundColor="#A2D149" TextColor="#1C262E" FontAttributes="Bold" CornerRadius="8" Clicked="OnGuardarClicked"/>
            </Grid>
        </Grid>

        <Grid x:Name="OverlayMarcas" BackgroundColor="#B3000000" IsVisible="False" Opacity="0">
            <Border VerticalOptions="Center" Margin="20" BackgroundColor="#1C262E" StrokeShape="RoundRectangle 20" Padding="20,25,20,25">
                <VerticalStackLayout Spacing="15">
                    <Label Text="NUEVA MARCA" TextColor="#A2D149" FontAttributes="Bold" FontSize="14" HorizontalOptions="Center"/>
                    <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                        <Entry x:Name="TxtNuevaMarca" TextColor="White" Placeholder="Nombre de la marca" HeightRequest="40"/>
                    </Border>
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                        <Button Grid.Column="0" Text="CANCELAR" BackgroundColor="#2E3842" TextColor="#939CA5" Clicked="OnCerrarOverlayMarcasClicked"/>
                        <Button Grid.Column="1" Text="GUARDAR" BackgroundColor="#A2D149" TextColor="#1C262E" Clicked="OnGuardarMarcaClicked"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid x:Name="OverlayProveedores" BackgroundColor="#B3000000" IsVisible="False" Opacity="0">
            <Border VerticalOptions="Center" Margin="20" BackgroundColor="#1C262E" StrokeShape="RoundRectangle 20" Padding="20,25,20,25">
                <ScrollView MaximumHeightRequest="500">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="REGISTRAR DISTRIBUIDOR OFICIAL" TextColor="#A2D149" FontAttributes="Bold" FontSize="13" HorizontalOptions="Center" CharacterSpacing="0.5"/>

                        <Label Text="Número de RUC (11 dígitos) *" TextColor="#939CA5" FontSize="12"/>
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                            <Border Grid.Column="0" StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                                <Entry x:Name="TxtPopupRuc" TextColor="White" Placeholder="Escribe el RUC..." PlaceholderColor="#606A72" Keyboard="Numeric" MaxLength="11" HeightRequest="40"/>
                            </Border>
                            <Button Grid.Column="1" Text="🔍 BUSCAR" BackgroundColor="#2E3842" TextColor="#A2D149" FontAttributes="Bold" WidthRequest="100" HeightRequest="40" CornerRadius="6" Clicked="OnBuscarRucPopupClicked"/>
                        </Grid>

                        <ActivityIndicator x:Name="ActCargandoRuc" IsRunning="False" IsVisible="False" Color="#A2D149" HorizontalOptions="Center" HeightRequest="25" WidthRequest="25"/>

                        <Label Text="Razón Social / Nombre Legal *" TextColor="#939CA5" FontSize="12"/>
                        <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                            <Entry x:Name="TxtPopupBusinessName" TextColor="White" Placeholder="Se rellenará automáticamente..." PlaceholderColor="#54606C" HeightRequest="40"/>
                        </Border>

                        <Label Text="Dirección Fiscal de la Empresa" TextColor="#939CA5" FontSize="12"/>
                        <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                            <Entry x:Name="TxtPopupAddress" TextColor="White" Placeholder="Dirección legal SUNAT..." PlaceholderColor="#54606C" HeightRequest="40"/>
                        </Border>

                        <Label Text="Nombre del Contacto / Vendedor" TextColor="#939CA5" FontSize="12"/>
                        <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                            <Entry x:Name="TxtPopupContactName" TextColor="White" Placeholder="Ej. Asesor de Ventas..." PlaceholderColor="#54606C" HeightRequest="40"/>
                        </Border>

                        <Label Text="Teléfono / Celular de Contacto" TextColor="#939CA5" FontSize="12"/>
                        <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                            <Entry x:Name="TxtPopupPhone" TextColor="White" Placeholder="Ej. 999888777" PlaceholderColor="#54606C" Keyboard="Telephone" HeightRequest="40"/>
                        </Border>

                        <Label Text="Correo Electrónico" TextColor="#939CA5" FontSize="12"/>
                        <Border StrokeShape="RoundRectangle 8" Stroke="#2E3842" BackgroundColor="#232B35" Padding="10,0">
                            <Entry x:Name="TxtPopupEmail" TextColor="White" Placeholder="Ej. ventas@proveedor.com" PlaceholderColor="#54606C" Keyboard="Email" HeightRequest="40"/>
                        </Border>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12" Margin="0,10,0,0">
                            <Button Grid.Column="0" Text="CANCELAR" BackgroundColor="#2E3842" TextColor="#939CA5" CornerRadius="6" HeightRequest="40" Clicked="OnCerrarOverlayProveedoresClicked"/>
                            <Button Grid.Column="1" Text="GUARDAR PROV" BackgroundColor="#A2D149" TextColor="#1C262E" FontAttributes="Bold" CornerRadius="6" HeightRequest="40" Clicked="OnGuardarProveedorClicked"/>
                        </Grid>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>

    </Grid>
</ContentPage>