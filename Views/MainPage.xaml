<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ControlInventarioMovil.Views.Controls"
             x:Class="ControlInventarioMovil.Views.MainPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <ContentView x:Name="InteractionDetector" BackgroundColor="Transparent">
        <ContentView.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnPageInteraction" />
        </ContentView.GestureRecognizers>

        <Grid RowDefinitions="Auto, Auto, *, Auto">

            <Grid Grid.Row="0" BackgroundColor="#1B4F5F" Padding="15,20" ColumnDefinitions="Auto, *, Auto">
                <Image Source="warehouse_icon.png" HeightRequest="25" WidthRequest="25" Grid.Column="0"/>
                <Label Text="ControlInventario - Móvil" TextColor="White" FontSize="18" 
                       VerticalOptions="Center" HorizontalOptions="Center" Grid.Column="1" />
                <Image Source="user_outline.png" HeightRequest="25" WidthRequest="25" Grid.Column="2"/>
            </Grid>

            <VerticalStackLayout Grid.Row="1" HorizontalOptions="Center" Spacing="2" Margin="0,20,0,0">
                <Label x:Name="lblNombre" Text="Hola..." FontSize="28" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center"/>
                <Label x:Name="lblRol" Text="Rol: ..." TextColor="Gray" HorizontalTextAlignment="Center" FontSize="15"/>
                <Border BackgroundColor="#D4E6D1" HorizontalOptions="Center" Padding="15,4" Margin="0,12">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Label Text="3 Reportes" TextColor="#4F7942" FontAttributes="Bold" FontSize="13"/>
                </Border>
            </VerticalStackLayout>

            <Grid Grid.Row="2" x:Name="ContenedorOrbital" HorizontalOptions="Center" VerticalOptions="Center" HeightRequest="280" WidthRequest="280">

                <Border x:Name="AroEnergia" 
        WidthRequest="200" 
        HeightRequest="200" 
        HorizontalOptions="Center" 
        VerticalOptions="Center" 
        TranslationY="-5"
        BackgroundColor="Transparent"
        StrokeThickness="3">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="100"/>
                    </Border.StrokeShape>
                    <Border.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1B4F5F" Offset="0.0" />
                            <GradientStop Color="#F5F5F5" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Stroke>
                </Border>

                <Grid x:Name="OrbitaRegistros" HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="False">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                        <Border HeightRequest="48" WidthRequest="48" Padding="8" BackgroundColor="White" StrokeThickness="1" Stroke="#d3d3d3">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24"/>
                            </Border.StrokeShape>
                            <Image Source="registros.png"/>
                        </Border>
                        <Label x:Name="TxtRegistros" Text="Registros" HorizontalOptions="Center" TextColor="Black" FontSize="12"/>
                    </VerticalStackLayout>
                </Grid>

                <Grid x:Name="OrbitaInventario" HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="False">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                        <Border HeightRequest="48" WidthRequest="48" Padding="8" BackgroundColor="White" StrokeThickness="1" Stroke="#d3d3d3">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24"/>
                            </Border.StrokeShape>
                            <Image Source="inventario.png"/>
                        </Border>
                        <Label x:Name="TxtInventario" Text="Inventario" HorizontalOptions="Center" TextColor="Black" FontSize="12"/>
                    </VerticalStackLayout>
                </Grid>

                <Grid x:Name="OrbitaReportes" HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="False">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                        <Border HeightRequest="48" WidthRequest="48" Padding="8" BackgroundColor="White" StrokeThickness="1" Stroke="#d3d3d3">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24"/>
                            </Border.StrokeShape>
                            <Image Source="reportes.png"/>
                        </Border>
                        <Label x:Name="TxtReportes" Text="Reportes" HorizontalOptions="Center" TextColor="Black" FontSize="12"/>
                    </VerticalStackLayout>
                </Grid>

                <Grid x:Name="OrbitaConfig" HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="False">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                        <Border HeightRequest="48" WidthRequest="48" Padding="8" BackgroundColor="White" StrokeThickness="1" Stroke="#d3d3d3">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24"/>
                            </Border.StrokeShape>
                            <Image Source="config.png"/>
                        </Border>
                        <Label x:Name="TxtConfig" Text="Configuración" HorizontalOptions="Center" TextColor="Black" FontSize="12"/>
                    </VerticalStackLayout>
                </Grid>

                <Border HeightRequest="120" WidthRequest="120" BackgroundColor="#A8D08D" StrokeThickness="0" TranslationY="-5">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="60"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#A8D08D" Offset="0,0" Radius="15" Opacity="0.5"/>
                    </Border.Shadow>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="Stock OK" FontSize="22" FontAttributes="Bold" TextColor="#1B4F5F" HorizontalOptions="Center"/>
                        <Label Text="1,240 artículos" FontSize="14" TextColor="#1B4F5F" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>
            <controls:FooterView Grid.Row="3" />
        </Grid>
    </ContentView>
</ContentPage>